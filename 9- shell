➗ 4. DIVISION SCRIPT
gedit soumya_div.sh
#!/bin/bash

echo "Soumya - Division Program"

echo "Enter first number:"
read a

echo "Enter second number:"
read b

if [ $b -ne 0 ]
then
    div=$((a / b))
    echo "Division = $div"
else
    echo "Cannot divide by zero"
fi



🎯 FINAL RUN COMMAND (SAME FOR ALL)
chmod +x filename.sh
./filename.sh
