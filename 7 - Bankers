#include <stdio.h>

int main() {
    int n=5,m=3;

    int alloc[5][3]={{0,1,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}};
    int max[5][3]={{7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}};
    int avail[3]={3,3,2};

    int need[5][3],finish[5]={0},safe[5],count=0;

    for(int i=0;i<n;i++)
        for(int j=0;j<m;j++)
            need[i][j]=max[i][j]-alloc[i][j];

    while(count<n){
        for(int i=0;i<n;i++){
            if(!finish[i]){
                int flag=1;
                for(int j=0;j<m;j++)
                    if(need[i][j]>avail[j]) flag=0;

                if(flag){
                    for(int j=0;j<m;j++)
                        avail[j]+=alloc[i][j];

                    safe[count++]=i;
                    finish[i]=1;
                }
            }
        }
    }

    printf("Safe Sequence: ");
    for(int i=0;i<n;i++)
        printf("P%d ",safe[i]);

    return 0;
}




📘 Theory

Used to avoid deadlock by checking if system is in safe state.

🧠 Algorithm
Input number of processes (n) and resources (m)
Read Allocation, Max, and Available matrices
Calculate Need matrix:
👉 Need[i][j] = Max[i][j] – Allocation[i][j]
Initialize Finish[i] = 0 for all processes
Find a process such that:
👉 Need[i] ≤ Available
If found:
Add Allocation to Available
Mark Finish[i] = 1
Add process to Safe Sequence
Repeat until all processes finish
If all Finish = 1 → SAFE STATE
Else → DEADLOCK
