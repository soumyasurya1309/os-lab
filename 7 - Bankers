#include <stdio.h>

int main() {
    int n, m;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter number of resources: ");
    scanf("%d", &m);

    int alloc[n][m], max[n][m], avail[m];
    int need[n][m], finish[n], safe[n];

    // Input Allocation Matrix
    printf("\nEnter Allocation Matrix:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            scanf("%d", &alloc[i][j]);
        }
    }

    // Input Max Matrix
    printf("\nEnter Max Matrix:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            scanf("%d", &max[i][j]);
        }
    }

    // Input Available Resources
    printf("\nEnter Available Resources:\n");
    for(int j = 0; j < m; j++) {
        scanf("%d", &avail[j]);
    }

    // Initialize finish = 0
    for(int i = 0; i < n; i++) {
        finish[i] = 0;
    }

    // Calculate Need Matrix
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            need[i][j] = max[i][j] - alloc[i][j];
        }
    }

    int count = 0;

    while(count < n) {
        int found = 0;

        for(int i = 0; i < n; i++) {
            if(!finish[i]) {
                int flag = 1;

                for(int j = 0; j < m; j++) {
                    if(need[i][j] > avail[j]) {
                        flag = 0;
                        break;
                    }
                }

                if(flag) {
                    for(int j = 0; j < m; j++) {
                        avail[j] += alloc[i][j];
                    }

                    safe[count++] = i;
                    finish[i] = 1;
                    found = 1;
                }
            }
        }

        // If no process can be allocated
        if(!found) {
            printf("\nSystem is NOT in safe state\n");
            return 0;
        }
    }

    // Print Safe Sequence
    printf("\nSafe Sequence: ");
    for(int i = 0; i < n; i++) {
        printf("P%d ", safe[i]);
    }

    return 0;
}




📘 Theory

Used to avoid deadlock by checking if system is in safe state.

🧠 Algorithm
Input number of processes (n) and resources (m)
Read Allocation, Max, and Available matrices
Calculate Need matrix:
👉 Need[i][j] = Max[i][j] – Allocation[i][j]
Initialize Finish[i] = 0 for all processes
Find a process such that:
👉 Need[i] ≤ Available
If found:
Add Allocation to Available
Mark Finish[i] = 1
Add process to Safe Sequence
Repeat until all processes finish
If all Finish = 1 → SAFE STATE
Else → DEADLOCK
