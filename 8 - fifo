#include <stdio.h>

int main() {
    int n, f, i, j, k;
    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter frame size: ");
    scanf("%d", &f);

    int pages[n], frame[f];
    int index = 0, faults = 0, hits = 0;

    printf("Enter page reference string:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    // Initialize frames
    for(i = 0; i < f; i++)
        frame[i] = -1;

    printf("\nPage\tFrames\t\tStatus\n");

    for(i = 0; i < n; i++) {
        int found = 0;

        // Check hit
        for(j = 0; j < f; j++) {
            if(frame[j] == pages[i]) {
                found = 1;
                hits++;
                break;
            }
        }

        // If not found → fault
        if(!found) {
            frame[index] = pages[i];
            index = (index + 1) % f;
            faults++;
        }

        // Print frame status
        printf("%d\t", pages[i]);
        for(k = 0; k < f; k++)
            printf("%d\t", frame[k]);

        if(found)
            printf("Hit\n");
        else
            printf("Fault\n");
    }

    printf("\nTotal Page Hits = %d\n", hits);
    printf("Total Page Faults = %d\n", faults);

    return 0;
}



📘 Theory

First page inserted is replaced first (queue method).
Simple but may cause Belady’s anomaly.

🧠 Algorithm
Input number of pages and frame size
Initialize frames to empty
For each page:
If page already present → Hit
Else:
Replace oldest page (FIFO)
Increase page fault
Repeat for all pages
Print total faults and hits

