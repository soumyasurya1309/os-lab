#include <stdio.h>

int main() {
    int n,i,j,temp;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    int pid[n],bt[n],pr[n],wt[n],tat[n];

    for(i=0;i<n;i++){
        pid[i]=i+1;
        printf("Enter BT & Priority for P%d: ",pid[i]);
        scanf("%d%d",&bt[i],&pr[i]);
    }

    // Sort by priority
    for(i=0;i<n;i++){
        for(j=i+1;j<n;j++){
            if(pr[i]>pr[j]){
                temp=pr[i]; pr[i]=pr[j]; pr[j]=temp;
                temp=bt[i]; bt[i]=bt[j]; bt[j]=temp;
                temp=pid[i]; pid[i]=pid[j]; pid[j]=temp;
            }
        }
    }

    wt[0]=0;
    for(i=1;i<n;i++)
        wt[i]=wt[i-1]+bt[i-1];

    for(i=0;i<n;i++)
        tat[i]=wt[i]+bt[i];

    printf("\nProcess\tBT\tPriority\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t\t%d\t%d\n",pid[i],bt[i],pr[i],wt[i],tat[i]);

    printf("\nGantt Chart:\n|");
    for(i=0;i<n;i++) printf(" P%d |",pid[i]);

    printf("\n0");
    for(i=0;i<n;i++) printf("    %d",tat[i]);

    return 0;
}



📘 Theory

Processes are executed based on priority value (lower value = higher priority).
Can cause starvation, solved using aging.

🧠 Algorithm
Input number of processes (n)
Read burst time and priority
Assign process IDs
Sort processes based on priority (ascending)
Set WT[0] = 0
For i = 1 to n-1:
👉 WT[i] = WT[i-1] + BT[i-1]
For all processes:
👉 TAT[i] = WT[i] + BT[i]
Print process table
Draw Gantt Chart
