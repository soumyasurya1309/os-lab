#include <stdio.h>

int main() {
    int n,i,j,temp;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    int pid[n],bt[n],wt[n],tat[n];

    for(i=0;i<n;i++){
        pid[i]=i+1;
        printf("Enter BT for P%d: ",pid[i]);
        scanf("%d",&bt[i]);
    }

    // Sorting
    for(i=0;i<n;i++){
        for(j=i+1;j<n;j++){
            if(bt[i]>bt[j]){
                temp=bt[i]; bt[i]=bt[j]; bt[j]=temp;
                temp=pid[i]; pid[i]=pid[j]; pid[j]=temp;
            }
        }
    }

    wt[0]=0;
    for(i=1;i<n;i++)
        wt[i]=wt[i-1]+bt[i-1];

    for(i=0;i<n;i++)
        tat[i]=wt[i]+bt[i];

    printf("\nProcess\tBT\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\n",pid[i],bt[i],wt[i],tat[i]);

    printf("\nGantt Chart:\n|");
    for(i=0;i<n;i++) printf(" P%d |",pid[i]);

    printf("\n0");
    for(i=0;i<n;i++) printf("    %d",tat[i]);

    return 0;
}




📘 Theory

Shortest Job First executes the process with minimum burst time first.
It gives minimum average waiting time but may cause starvation.

🧠 Algorithm
Input number of processes (n)
Read burst time for all processes
Assign process IDs
Sort processes in ascending order of burst time
Set WT[0] = 0
For i = 1 to n-1:
👉 WT[i] = WT[i-1] + BT[i-1]
For all processes:
👉 TAT[i] = WT[i] + BT[i]
Print process table
Draw Gantt Chart
